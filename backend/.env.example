# Application Settings
APP_NAME=Multi Agent Starter Backend
APP_ENV=development
API_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# LLM Provider Configuration
LLM_PROVIDER=huggingface

# Hugging Face API (Replace with your key)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Model Configuration
MODEL_SUMMARIZATION=deepseek-ai/DeepSeek-V4-Pro
MODEL_CODE_GENERATION=Qwen/Qwen2.5-Coder-7B-Instruct
MODEL_QUESTION_ANSWERING=Qwen/Qwen2.5-7B-Instruct
MODEL_REASONING=deepseek-ai/DeepSeek-V4-Pro

# Redis Configuration
REDIS_URL=redis://:redis_password@localhost:6379/0
REDIS_TTL_SECONDS=3600

# Supabase Configuration
SUPABASE_URL=https://your_supabase_project_ref.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
SUPABASE_STORAGE_BUCKET=user-documents

# Embedding Model Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMS=384
EMBEDDING_CACHE_TTL=86400

# Text Chunking Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Vector Search Settings
VECTOR_TOP_K=10

# Reranker Model Settings
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=5


# Langfuse Observability (Replace with your keys)
LANGFUSE_ENABLED=true
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENV=production
LANGFUSE_USER_ID=user-dev

# Authentication
AUTH_SECRET_KEY=change-me-in-real-projects-use-long-random-string
AUTH_ALGORITHM=HS256
AUTH_TOKEN_EXPIRY_MINUTES=120